# HH Vacancy Manager — Search Profile
# Шаблон профиля поиска. Скопируйте и адаптируйте под себя.

name: "Default Profile"
city: "Уфа"

# Приоритетные районы (для скоринга)
priority_districts:
  - "Шакша"
  - "Калининский"

# Навыки (для AI-скоринга)
skills:
  - "Работа с клиентами"
  - "Касса"
  - "Консультирование"

# Точно не подходит (для скоринга)
not_suitable:
  - "Физический труд"
  - "Кол-центр"
  - "Вахта"
  - "Склад"

# Поисковые запросы
search:
  queries:
    - "продавец"
    - "консультант"
    - "оператор"
    - "администратор"
    - "менеджер"
  area: 99  # Уфа
  salary_min: 0
  schedule: "fullTime"
  experience: ""
  exclude_words:
    - "водитель"
    - "грузчик"
    - "разнорабочий"
    - "курьер"
    - "вахта"
    - "кол-центр"
    - "call-центр"
    - "call center"
    - "телефон"
    - "холодн"
    - "супермаркет"
    - "гипермаркет"
    - "пятёрочка"
    - "магнит"
    - "лента"
    - "дикси"
    - "перекрёсток"
    - "склад"
    - "комплектовщик"
    - "сборщик"
    - "фасовщик"
    - "упаковщик"
    - "физическ"
    - "ручной труд"
    - "производство"
    - "завод"
    - "цех"

# Удалённый поиск
remote_search:
  enabled: true
  queries:
    - "оператор ПК"
    - "модератор"
    - "администратор интернет-магазин"
    - "специалист поддержки"
    - "диспетчер"
    - "помощник руководителя"
    - "секретарь"
    - "менеджер маркетплейс"
    - "контент-менеджер"
    - "специалист чат"
  area: 113  # Россия
  salary_min: 40000
  exclude_words:
    - "кол-центр"
    - "call-центр"
    - "call center"
    - "телефон"
    - "холодн"
    - "продаж"
    - "водитель"
    - "курьер"
    - "грузчик"
    - "разнорабочий"
    - "вахта"
    - "склад"
    - "производство"
    - "завод"
    - "цех"
    - "фриланс"
    - "1С программист"
    - "программист"
    - "разработчик"
    - "тестировщик"
    - "системный администратор"
    - "DevOps"
    - "аналитик данных"
    - "Data Scientist"
