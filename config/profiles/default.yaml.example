# HH Vacancy Manager — конфигурация профилей
#
# Один или несколько людей (family members), каждый — со своим списком
# независимо настроенных поисков. У одного и того же человека может быть
# несколько поисков с совершенно разными критериями важности — например,
# удалённая работа по всей России (где интересность задач — приоритет) и
# работа рядом с домом (где важнее близость, а не интересность). Критерии
# и заметки для AI задаются на уровне поиска, а не человека.

people:
  - name: "Мама"
    city: "Уфа"
    searches:
      # ── Удалёнка по всей России: интересность задач — главный критерий ──
      - name: "Удалёнка по России"
        queries:
          - "оператор ПК"
          - "модератор"
          - "администратор интернет-магазин"
          - "специалист поддержки"
          - "диспетчер"
          - "помощник руководителя"
          - "секретарь"
          - "менеджер маркетплейс"
          - "контент-менеджер"
          - "специалист чат"
        area: 113 # Россия
        schedule: "remote"
        salary_min: 40000
        priority_districts: []
        skills:
          - "Работа с клиентами"
          - "Консультирование"
        not_suitable:
          - "Кол-центр"
          - "Телефонные продажи"
        exclude_words:
          - "кол-центр"
          - "call-центр"
          - "call center"
          - "телефон"
          - "холодн"
          - "продаж"
          - "водитель"
          - "курьер"
          - "грузчик"
          - "разнорабочий"
          - "вахта"
          - "склад"
          - "производство"
          - "завод"
          - "цех"
          - "фриланс"
          - "1С программист"
          - "программист"
          - "разработчик"
          - "тестировщик"
          - "системный администратор"
          - "DevOps"
          - "аналитик данных"
          - "Data Scientist"
        ai_notes: >
          Приоритет — интересность и разнообразие задач: аналитическое мышление,
          коммуникация, непредсказуемый процесс. Монотонная работа штрафуется
          сильно, даже при хорошей оплате — удалёнка ценна только если сама
          работа увлекательная, иначе смысла ехать "далеко" за неё нет.

      # ── Рядом с домом: близость важнее интересности задач ──
      - name: "Рядом с домом"
        queries:
          - "продавец"
          - "консультант"
          - "оператор"
          - "администратор"
          - "менеджер"
        area: 99 # Уфа
        schedule: "fullTime"
        salary_min: 0
        priority_districts:
          - "Шакша"
          - "Калининский"
        skills:
          - "Работа с клиентами"
          - "Касса"
          - "Консультирование"
        not_suitable:
          - "Физический труд"
          - "Склад"
          - "Производство"
        exclude_words:
          - "водитель"
          - "грузчик"
          - "разнорабочий"
          - "курьер"
          - "вахта"
          - "кол-центр"
          - "call-центр"
          - "call center"
          - "телефон"
          - "холодн"
          - "супермаркет"
          - "гипермаркет"
          - "пятёрочка"
          - "магнит"
          - "лента"
          - "дикси"
          - "перекрёсток"
          - "склад"
          - "комплектовщик"
          - "сборщик"
          - "фасовщик"
          - "упаковщик"
          - "физическ"
          - "ручной труд"
          - "производство"
          - "завод"
          - "цех"
        ai_notes: >
          Приоритет — близость к дому (Шакша, Калининский район) и нормальные
          условия труда. Интересность задач вторична: рутинная, но спокойная
          работа рядом с домом полностью приемлема.

  # Добавить второго человека — просто ещё один элемент списка, без правок кода:
  # - name: "Имя"
  #   city: "..."
  #   searches:
  #     - name: "..."
  #       queries: [...]
  #       ...
