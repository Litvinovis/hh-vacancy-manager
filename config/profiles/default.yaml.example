# HH Vacancy Manager — Конфигурация профилей
# Каждый профиль — отдельный человек с настройками

profiles:
  # Профиль по умолчанию (мама)
  mom:
    name: "Мама"
    city: "Уфа"
    priority_districts:
      - "Шакша"
      - "Калининский"
    skills:
      - "Работа с клиентами"
      - "Касса"
      - "Консультирование"
    not_suitable:
      - "Физический труд"
      - "Кол-центр"
      - "Вахта"
      - "Склад"
      - "Производство"
      - "Супермаркет"
      - "Телефонные продажи"

    # ── Поиски (список, можно добавлять сколько угодно) ──
    # Каждый поиск: name, queries, area, + опциональные поля
    searches:
      # Офлайн поиск (Уфа)
      - name: "Оффлайн Уфа"
        queries:
          - "продавец"
          - "консультант"
          - "оператор"
          - "администратор"
          - "менеджер"
        area: 99  # Уфа
        schedule: "fullTime"
        salary_min: 0
        exclude_words:
          - "водитель"
          - "грузчик"
          - "разнорабочий"
          - "курьер"
          - "вахта"
          - "кол-центр"
          - "call-центр"
          - "call center"
          - "телефон"
          - "холодн"
          - "супермаркет"
          - "гипермаркет"
          - "пятёрочка"
          - "магнит"
          - "лента"
          - "дикси"
          - "перекрёсток"
          - "склад"
          - "комплектовщик"
          - "сборщик"
          - "фасовщик"
          - "упаковщик"
          - "физическ"
          - "ручной труд"
          - "производство"
          - "завод"
          - "цех"

      # Удалённый поиск (вся Россия)
      - name: "Удалёнка РФ"
        queries:
          - "оператор ПК"
          - "модератор"
          - "администратор интернет-магазин"
          - "специалист поддержки"
          - "диспетчер"
          - "помощник руководителя"
          - "секретарь"
          - "менеджер маркетплейс"
          - "контент-менеджер"
          - "специалист чат"
        area: 113  # Россия
        schedule: "remote"
        salary_min: 40000
        exclude_words:
          - "кол-центр"
          - "call-центр"
          - "call center"
          - "телефон"
          - "холодн"
          - "продаж"
          - "водитель"
          - "курьер"
          - "грузчик"
          - "разнорабочий"
          - "вахта"
          - "склад"
          - "производство"
          - "завод"
          - "цех"
          - "фриланс"
          - "1С программист"
          - "программист"
          - "разработчик"
          - "тестировщик"
          - "системный администратор"
          - "DevOps"
          - "аналитик данных"
          - "Data Scientist"

    # Настройки скоринга
    scoring:
      rules_file: "config/rules.yaml"
      min_score_for_notify: 50
      max_per_run: 20

    # Настройки уведомлений
    notifications:
      enabled: true
      telegram_chat_id: "${TELEGRAM_CHAT_ID}"
      min_score: 60
      max_per_day: 10

# ─── Источники данных ─────────────────────────────────────────────────────────
sources:
  hh_api:
    enabled: true
    type: "api"
    base_url: "https://api.hh.ru/vacancies"
    delay: 1.5
    per_page: 100
    max_pages: 20

# ─── AI настройки ──────────────────────────────────────────────────────────────
ai:
  enabled: true
  api_url: "${AI_API_URL:https://openrouter.ai/api/v1/chat/completions}"
  api_key: "${AI_API_KEY}"
  model: "${AI_MODEL:openrouter/auto}"
  batch_size: 5
  max_per_run: 20

# ─── Telegram ──────────────────────────────────────────────────────────────────
telegram:
  bot_token: "${TELEGRAM_BOT_TOKEN}"
  chat_id: "${TELEGRAM_CHAT_ID}"
  max_vacancies_in_message: 10
